#!/usr/bin/env bash
set -e

usage="usage: $(basename "$0") [nowplaying | lyrics <args>]

  nowplaying (np)       show the currently playing song as a terminal-notifier notification
  lyrics (lr)           display the currently playing song's lyrics in \$PAGER, also accepts a string to search for as an argument
"

vars () {

enc="$(echo -n "$(pass show Media/spt \
  | gsed -z 's/\n/:/')" \
  | openssl base64 \
  | tr -d '\n')"

token=$(curl -sX "POST" -H "Authorization: Basic $enc" \
  -d grant_type=client_credentials https://accounts.spotify.com/api/token \
  | jq '.access_token' \
  | tr -d '"')

trackid=$(spt playback --share-track \
  | sed 's/https:\/\/open.spotify.com\/track\///')

trackimage=$(curl -s "https://open.spotify.com/oembed?url=spotify:track:$trackid" | jq '.thumbnail_url')

trackinfo=$(curl -sX "GET" "https://api.spotify.com/v1/tracks/$trackid?market=ES" -H "Accept: application/json" -H "Content-Type: application/json" -H "Authorization: Bearer $token")
}

nowplaying () {
  vars

  terminal-notifier \
    -title "$(echo "$trackinfo" | jq '.name' | tr -d '"')" \
    -contentImage "$trackimage" \
    -open "$(spt playback --share-album)" \
    -message "$(echo "$trackinfo" | jq '.artists[] .name' | tr -d '"')"
}

lyrics () {
  vars

  export GENIUS_ACCESS_TOKEN
  GENIUS_ACCESS_TOKEN="$(pass show Media/Genius | tail -n1)";

  fullname="$(echo "$trackinfo" \
    | jq '.name' \
    | sed 's/^"//; s/"$//') $(echo "$trackinfo" \
    | jq '.artists[] .name' \
    | sed 's/^"//; s/"$//')"

  temp="$(mktemp -d)"
  cd "$temp"

  if [ "$2" != "" ]; then
    lyricsgenius --save song "$2"
  else
    lyricsgenius --save song "$fullname"
  fi

  jq '.lyrics' lyrics*.json \
    | gsed -r '1s/^"//; $s/"$//; $s/[0-9]*Embed$//; s/\\n/\n/g; 1s/(.*Lyrics)(.*)/\1\n\n\2/' \
    | $PAGER
  rm -r "$temp"
}

case "$1" in
  "np"|"nowplaying")
    nowplaying
    ;;
  "lr"|"lyrics")
    lyrics "$@"
    ;;
  *)
    echo "$usage"
    ;;
esac
