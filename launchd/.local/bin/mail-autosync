#!/usr/bin/env bash
PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/shreeram/.nix-profile/bin:/opt/homebrew/bin"

out="$(mailsync)"
line="$(echo "$out" | tail -n1)"

case "$line" in
  *Added*)
    echo "$line" | terminal-notifier -title "Neomutt" -appIcon "https://neomutt.org/images/mutt-48x48.png" -activate "net.kovidgoyal.kitty"
    ;;
esac
