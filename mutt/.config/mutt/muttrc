# vim: filetype=neomuttrc
source /usr/local/share/mutt-wizard/mutt-wizard.muttrc
source /Users/shreeram/.config/mutt/accounts/shreerammodi10@gmail.com.muttrc
macro index,pager i1 '<sync-mailbox><enter-command>source /Users/shreeram/.config/mutt/accounts/shreerammodi10@gmail.com.muttrc<enter><change-folder>!<enter>;<check-stats>' "switch to shreerammodi10@gmail.com"


# Send mail to custom folder
macro index Me ":set confirmappend=no delete=yes\n<tag-prefix><save-message>=archive\n<sync-mailbox>:set confirmappend=yes delete=ask-yes\n"

macro index,pager Mc ";<save-message>=College<enter>" "move mail to college"
macro index,pager Cc ";<copy-message>=College<enter>" "copy mail to college"

macro index,pager Mr ";<save-message>=Receipts<enter>" "move mail to receipts"
macro index,pager Cr ";<copy-message>=Receipts<enter>" "copy mail to receipts"

macro index,pager Mr ";<save-message>=Receipts<enter>" "move mail to receipts"
macro index,pager Cr ";<copy-message>=Receipts<enter>" "copy mail to receipts"

macro index,pager gt "<change-folder>=TODO<enter>" "go to todo"
macro index,pager gd "<change-folder>=Trash<enter>" "go to trash"

bind index,pager \Cn next-subthread
bind index,pager \Cp previous-subthread

bind index,pager \Cl sidebar-open

bind index \Ct tag-pattern
bind index \Cr untag-pattern

bind index,pager p recall-message
bind index,pager P print-message

set use_threads=yes

color sidebar_highlight brightcyan default

set postponed = "+[Gmail]/Drafts"
set trash = "+[Gmail]/Trash"
set record = "+[Gmail]/Sent Mail"

set sidebar_delim_chars = '/'
set sidebar_divider_char = '|'
set sidebar_folder_indent
set sidebar_indent_string = '  '
