# Taps

tap "homebrew/bundle"
tap "homebrew/cask"
tap "homebrew/core"
tap "homebrew/services"
tap "shrimpram/tap"
tap "koekeishiya/formulae"
tap "cmacrae/formulae"

# Core

brew "gnu-sed"
brew "pinentry-mac"
brew "koekeishiya/formulae/yabai"
brew "koekeishiya/formulae/skhd"
brew "spacebar"

# Cask

cask "anki"
cask "appcleaner"
cask "authy"
cask "discord"
cask "dropbox"
cask "firefox"
cask "flux"
cask "foxitreader"
cask "iina"
cask "inform"
cask "inky"
cask "jabref"
cask "logseq"
cask "mac-mouse-fix"
cask "malwarebytes"
cask "messenger"
cask "obsidian"
cask "raycast"
cask "signal"
cask "slack"
cask "spotify"
cask "syncthing"
cask "visual-studio-code"
cask "whatsapp"
cask "zotero"


# Optionals for mutt

brew "abook"

