[general]
status_path = "~/.local/share/vdirsyncer/status/"

[pair cal]
a = "local_calendar"
b = "google_calendar"
collections = ["from a", "from b"]

[storage google_calendar]
type = "google_calendar"
token_file = "~/.local/share/vdirsyncer/calendar-token"
client_id.fetch = ["command", "pass", "Vdirsyncer/ID"]
client_secret.fetch = ["command", "pass", "Vdirsyncer/Secret"]

[storage local_calendar]
type = "filesystem"
path = "~/.local/share/khal/calendars/private/"
fileext = ".ics"

[pair contacts]
a = "local_contacts"
b = "google_contacts"
collections = ["from a", "from b"]

[storage google_contacts]
type = "google_contacts"
token_file = "~/.local/share/vdirsyncer/contacts-token"
client_id.fetch = ["command", "pass", "Vdirsyncer/ID"]
client_secret.fetch = ["command", "pass", "Vdirsyncer/Secret"]

[storage local_contacts]
type = "filesystem"
path = "~/.local/share/khard/"
fileext = ".vcf"
