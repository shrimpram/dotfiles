unmailboxes *

set folder = "/Users/shreeram/.local/share/mail/shreeram@smodi.net"
set from = "shreeram@smodi.net"
set hostname = "fastmail.com"
set mbox_type = Maildir
set postponed = "+Drafts"
set real_name = "Shreeram Modi"
set record = "+Sent"
set sendmail = "msmtp -a shreeram@smodi.net"
set spool_file = "+INBOX"
set trash = "+Trash"

mailboxes \
            =Applications       \
            =Archive            \
            =Debate/Lynbrook    \
            =Drafts             \
            =INBOX              \
            =Notes              \
            =Receipts           \
            =Scheduled          \
            =Sent               \
            =Spam               \
            =Trash

macro index,pager P \
  "<save-message>=Archive<enter>" \
  "Save message to Archive mailbox"
